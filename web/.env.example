# Supabase (Postgres)
# Project Settings → Database → Connection string
# Transaction pooler (app runtime, port 6543):
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (migrations, port 5432):
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Assistente Analisi (Claude). Crea la chiave su console.anthropic.com → API keys
# e carica un po' di credito. Senza questa variabile l'assistente è disattivato.
ANTHROPIC_API_KEY=

# Email (reset password + feedback) via SMTP — es. Gmail.
# SMTP_PASS = "App Password" Google (Sicurezza → Verifica in due passaggi → Password per le app),
# NON la password normale di Gmail. Mittente mostrato: Stacca <SMTP_USER>.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FEEDBACK_TO_EMAIL=admin@example.com

# Account "titolare" protetto: non modificabile / disattivabile / resettabile da
# altri admin (solo da sé). Opzionale — se vuoto usa FEEDBACK_TO_EMAIL.
PROTECTED_ADMIN_EMAIL=

# URL pubblico dell'app per i link nelle email (es. https://stacca-app.vercel.app).
# Opzionale: su Vercel viene usato in automatico VERCEL_PROJECT_PRODUCTION_URL.
APP_URL=

# Google Sheets — invio mese
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB="Ore Totali"
GOOGLE_SHEETS_COMPANY_NAME="Corzano e Paterno"
# Spazio prima del nome aggiunto in automatico → tab "Ore Rocco"
GOOGLE_SHEETS_PRESENZE_TAB_PREFIX="Ore"
# Local dev: path to JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json
# Vercel: paste entire JSON as one line, OR use:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
