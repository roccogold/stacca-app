# Google Sheets — invio mese
# 1. Google Cloud Console → API "Google Sheets" attiva
# 2. Service Account → scarica JSON → salva come google-service-account.json in web/
# 3. Condividi il foglio con client_email del JSON (Editor)
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=Ore
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json
# Alternativa: email + chiave nel .env invece del file JSON
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
