# Supabase (Postgres)
# Project Settings → Database → Connection string
# Transaction pooler (app runtime, port 6543):
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (migrations, port 5432):
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Email — reset password + feedback.
# Due modi (se imposti SMTP_*, hanno PRIORITÀ su Resend):
#
# 1) SMTP (es. Gmail) — invia a chiunque senza verificare un dominio.
#    SMTP_PASS = "App Password" Google (Sicurezza → Verifica in due passaggi → Password per le app).
#    Mittente mostrato: Stacca <SMTP_USER>.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
#
# 2) Resend — test mode (onboarding@resend.dev) consegna SOLO all'indirizzo dell'account Resend;
#    per inviare a tutti serve verificare un dominio.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
FEEDBACK_TO_EMAIL=roccogold23@gmail.com

# Google Sheets — invio mese
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB="Ore Totali"
GOOGLE_SHEETS_COMPANY_NAME="Corzano e Paterno"
# Spazio prima del nome aggiunto in automatico → tab "Presenze Rocco"
GOOGLE_SHEETS_PRESENZE_TAB_PREFIX="Presenze"
# Local dev: path to JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json
# Vercel: paste entire JSON as one line, OR use:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
