generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String      @id @default(cuid())
  handle             String      @unique
  displayName        String
  email              String?     @unique
  passwordHash       String?
  mustChangePassword Boolean     @default(false)
  resetCodeHash      String?
  resetCodeExpiresAt DateTime?
  entries            TimeEntry[]
  monthSubmissions   MonthSubmission[]
  createdAt          DateTime    @default(now())
}

model MonthSubmission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String
  totalHours  Float
  submittedAt DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  hours     Float
  mansione  String
  luogo     String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}
