// ─────────────────────────────────────────────────────────────────────────────
// Naming conventions — keep consistent when adding models/fields:
//   • Tables (models): PascalCase, singular   — User, TimeEntry, MonthSubmission
//   • Columns (fields): camelCase             — displayName, totalHours, createdAt
//   • Primary key: `id` (cuid). Foreign key: `<model>Id` (e.g. userId)
//   • Timestamps: createdAt / updatedAt, or past-tense event time (submittedAt)
//   • Enums: PascalCase type, lowercase values — UserRole { admin, dipendente }
//   • Language: English by default. A few established Italian DOMAIN terms are
//     kept on purpose to match the Italian UI + payroll sheet: `mansione` (task),
//     `luogo` (site), and the role value `dipendente`. Don't "fix" these.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  dipendente
}

model User {
  id                 String      @id @default(cuid())
  handle             String      @unique
  displayName        String
  firstName          String      @default("")
  lastName           String      @default("")
  role               UserRole    @default(dipendente)
  disabled           Boolean     @default(false)
  archived           Boolean     @default(false)
  email              String?     @unique
  passwordHash       String?
  mustChangePassword Boolean     @default(false)
  resetCodeHash      String?
  resetCodeExpiresAt DateTime?
  entries            TimeEntry[]
  monthSubmissions   MonthSubmission[]
  createdAt          DateTime    @default(now())
}

model MonthSubmission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String
  totalHours  Float
  submittedAt DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  hours     Float
  mansione  String
  luogo     String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}
