// ─────────────────────────────────────────────────────────────────────────────
// Naming conventions — keep consistent when adding models/fields:
//   • Tables (models): PascalCase, singular   — User, TimeEntry, MonthSubmission
//   • Columns (fields): camelCase             — displayName, totalHours, createdAt
//   • Primary key: `id` (cuid). Foreign key: `<model>Id` (e.g. userId)
//   • Timestamps: createdAt / updatedAt, or past-tense event time (submittedAt)
//   • Enums: PascalCase type, lowercase values — UserRole { admin, dipendente }
//   • Language: English by default. A few established Italian DOMAIN terms are
//     kept on purpose to match the Italian UI + payroll sheet: `mansione` (task),
//     `luogo` (site), and the role value `dipendente`. Don't "fix" these.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  dipendente
}

model User {
  id                 String      @id @default(cuid())
  handle             String      @unique
  displayName        String
  firstName          String      @default("")
  lastName           String      @default("")
  role               UserRole    @default(dipendente)
  disabled           Boolean     @default(false)
  archived           Boolean     @default(false)
  email              String?     @unique
  passwordHash       String?
  mustChangePassword Boolean     @default(false)
  resetCodeHash      String?
  resetCodeExpiresAt DateTime?
  entries            TimeEntry[]
  monthSubmissions   MonthSubmission[]
  areas              UserArea[]
  createdAt          DateTime    @default(now())
}

model MonthSubmission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String
  totalHours  Float
  submittedAt DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  hours     Float
  mansione  String
  luogo     String
  area      String   @default("") // denormalized area name (like mansione/luogo)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

// Registro azioni admin (audit log). Si consulta direttamente su Supabase
// (Table Editor / SQL editor) — non c'è UI nell'app. Si scrive una riga dalle
// route admin a ogni modifica: chi (actorName denormalizzato così resta leggibile
// anche se l'utente viene rimosso), cosa (action, es. "area.create"), su cosa
// (target, es. il nome del settore/dipendente toccato). Le ore dei dipendenti
// NON finiscono qui: hanno già createdAt/updatedAt e creerebbero solo rumore.
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorName String
  action    String
  target    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Settori aziendali (Vigna, Cantina, Caseificio, Stalla, …). Le lavorazioni e i
// luoghi appartengono a un'area; ai dipendenti si assegnano una o più aree e nel
// form vedono solo le opzioni delle loro aree.
model Area {
  id          String        @id @default(cuid())
  name        String        @unique
  archived    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lavorazioni Lavorazione[]
  luoghi      Luogo[]
  users       UserArea[]
}

// Join esplicito User ↔ Area (molti-a-molti), per controllare RLS.
model UserArea {
  userId String
  areaId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
  @@index([areaId])
}

// Admin-managed option lists for the entry form. TimeEntry stores `mansione`
// and `luogo` as denormalized strings (the chosen `name`), so renaming/archiving
// here only affects the dropdown going forward — historical entries keep the
// value they were saved with. The catch-all "Altro" is reserved in code and is
// NOT stored as a row.
model Lavorazione {
  id        String   @id @default(cuid())
  name      String
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id], onDelete: Restrict)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, name])
  @@index([areaId])
}

model Luogo {
  id        String   @id @default(cuid())
  name      String
  category  String // legacy "vigne"|"altro" — non più usato, sostituito da areaId
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id], onDelete: Restrict)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, name])
  @@index([areaId])
  @@index([category])
}
